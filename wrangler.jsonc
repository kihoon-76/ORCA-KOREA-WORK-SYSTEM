{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "orca-korea-work-system",
  "main": "worker/index.ts",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./web/dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "JWT_SECRET": "dev-secret-change-in-production"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "orca-db",
      "database_id": "e54e642b-e5ec-42fe-82a2-a82816be033c"
    }
  ],
  "r2_buckets": [
    {
      "binding": "FILES",
      "bucket_name": "orca-files"
    }
  ]
}
