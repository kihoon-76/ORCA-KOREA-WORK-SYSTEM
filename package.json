{
  "name": "orca-korea-work-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "build": "vite build && node scripts/build-worker.mjs",
    "build:web": "vite build",
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:init": "wrangler d1 execute orca-db --local --file=./schema.sql",
    "db:seed": "wrangler d1 execute orca-db --local --file=./seed.sql",
    "db:init:remote": "wrangler d1 execute orca-db --remote --file=./schema.sql",
    "db:seed:remote": "wrangler d1 execute orca-db --remote --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wrangler": "^4.95.0"
  }
}
